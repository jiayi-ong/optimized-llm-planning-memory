# ── LLM Provider API Keys ────────────────────────────────────────────────────
# litellm reads these automatically from the environment.
# Set only the keys for the provider(s) you intend to use.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...          # Vertex AI / Gemini
AZURE_API_KEY=...
AZURE_API_BASE=https://your-deployment.openai.azure.com/
AZURE_API_VERSION=2024-02-01

# ── Agent LLM (planning agent) ───────────────────────────────────────────────
# litellm model string — swap provider by changing this value only.
# Examples: "openai/gpt-4o-mini", "anthropic/claude-3-5-haiku-20241022",
#           "vertex_ai/gemini-1.5-flash"
AGENT_LLM_MODEL_ID=openai/gpt-4o-mini

# ── Evaluation Judge LLM ─────────────────────────────────────────────────────
# Fixed across all evaluation runs for fair comparison between baselines.
JUDGE_LLM_MODEL_ID=openai/gpt-4o

# ── Weights & Biases (optional) ──────────────────────────────────────────────
WANDB_API_KEY=...
WANDB_PROJECT=optllm-planning
WANDB_ENTITY=your-team

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
